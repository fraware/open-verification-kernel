{
  "schema_version": "ovk.external_validation.scenarios.v1",
  "scenarios": [
    {
      "id": "check_strict_block",
      "kind": "action_check",
      "description": "Strict mode blocks when secrets appear in untrusted CI context",
      "mode": "strict",
      "changed_files": "examples/ci_secrets/workflow_secrets_on_pr.diff",
      "expected_recommendation": "block",
      "expect_exit_code": 1,
      "action_inputs": {
        "use-check": "true",
        "changed-files": "examples/ci_secrets/workflow_secrets_on_pr.diff",
        "emit-check": "true"
      }
    },
    {
      "id": "check_advisory_allow",
      "kind": "action_ci",
      "description": "Advisory mode allows preserved gate metadata",
      "mode": "advisory",
      "changed_files": "examples/no_agent_self_approval/changed_files_workflow.txt",
      "metadata": "examples/no_agent_self_approval/metadata_missing_required_checks.json",
      "expected_recommendation": "allow",
      "expect_exit_code": 0,
      "action_inputs": {
        "use-check": "false",
        "changed-files": "examples/no_agent_self_approval/changed_files_workflow.txt",
        "metadata": "examples/no_agent_self_approval/metadata_missing_required_checks.json",
        "emit-check": "false"
      }
    },
    {
      "id": "mvp_manifest_allow",
      "kind": "action_manifest",
      "description": "Full MVP manifest produces valid advisory bundle",
      "mode": "advisory",
      "verification_manifest": "examples/verification_manifests/full_mvp.json",
      "expected_recommendation": "allow",
      "expect_exit_code": 0,
      "validate_bundle": true,
      "action_inputs": {
        "verification-manifest": "examples/verification_manifests/full_mvp.json",
        "bundle-output-dir": "external-validation-mvp-bundle",
        "emit-check": "false"
      }
    },
    {
      "id": "forged_bundle_rejected",
      "kind": "quality_gate",
      "description": "Adversarial forged bundle fails quality gate",
      "input_bundle": "examples/evidence_quality/adversarial_allow_with_fail.json",
      "expected_recommendation": "quality_fail",
      "expect_exit_code": 0
    },
    {
      "id": "external_pilot_advisory",
      "kind": "action_check",
      "description": "External pilot advisory path reports block without failing the job",
      "mode": "advisory",
      "changed_files": "examples/ci_secrets/workflow_secrets_on_pr.diff",
      "expected_recommendation": "block",
      "expect_exit_code": 0,
      "action_inputs": {
        "use-check": "true",
        "changed-files": "examples/ci_secrets/workflow_secrets_on_pr.diff",
        "emit-check": "false"
      }
    },
    {
      "id": "check_strict_emit_check",
      "kind": "action_check",
      "description": "Strict mode with emit-check blocks and requires check emission",
      "mode": "strict",
      "changed_files": "examples/ci_secrets/workflow_secrets_on_pr.diff",
      "expected_recommendation": "block",
      "expect_exit_code": 1,
      "action_inputs": {
        "use-check": "true",
        "changed-files": "examples/ci_secrets/workflow_secrets_on_pr.diff",
        "emit-check": "true"
      }
    }
  ]
}
