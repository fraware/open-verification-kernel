{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openverification.dev/schemas/preflight.report.schema.json",
  "title": "Preflight Report",
  "type": "object",
  "required": ["passed", "checks"],
  "properties": {
    "passed": { "type": "boolean" },
    "checks": {
      "type": "array",
      "items": { "$ref": "#/$defs/check" }
    },
    "optional_checks": {
      "type": "array",
      "items": { "$ref": "#/$defs/check" }
    }
  },
  "$defs": {
    "check": {
      "type": "object",
      "required": ["name", "passed"],
      "properties": {
        "name": { "type": "string" },
        "passed": { "type": "boolean" },
        "messages": {
          "type": "array",
          "items": { "type": "string" }
        },
        "failures": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
