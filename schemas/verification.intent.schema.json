{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openverification.dev/schemas/verification.intent.schema.json",
  "title": "Verification Intent",
  "type": "object",
  "required": ["intent_id", "version", "domain", "title", "property", "risk", "merge_policy"],
  "properties": {
    "intent_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "domain": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "scope": {
      "type": "object",
      "properties": {
        "files": { "type": "array", "items": { "type": "string" } },
        "repo_controls_required": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "actor": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "id": { "type": "string" }
      },
      "additionalProperties": true
    },
    "resource": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "selector": { "type": "string" }
      },
      "additionalProperties": true
    },
    "operation": { "type": "string" },
    "property": {
      "type": "object",
      "required": ["kind", "natural_language"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["safety", "invariant", "access_control", "data_boundary", "forbidden_configuration", "liveness", "equivalence", "refinement", "runtime_monitorable"]
        },
        "natural_language": { "type": "string", "minLength": 1 },
        "formal_hint": { "type": "string" }
      },
      "additionalProperties": true
    },
    "failure_modes": { "type": "array", "items": { "type": "string" } },
    "acceptable_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": { "type": "string" },
          "minimum_confidence": { "type": "string" },
          "required_for_override": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    },
    "risk": {
      "type": "object",
      "required": ["severity"],
      "properties": {
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "likelihood": { "type": "string", "enum": ["low", "medium", "high"] },
        "rationale": { "type": "string" }
      },
      "additionalProperties": true
    },
    "merge_policy": {
      "type": "object",
      "required": ["on_pass", "on_fail", "on_unknown"],
      "properties": {
        "on_pass": { "type": "string", "enum": ["allow", "allow_with_warning", "require_human_review"] },
        "on_fail": { "type": "string", "enum": ["block", "require_human_review"] },
        "on_unknown": { "type": "string", "enum": ["block", "require_human_review", "allow_with_warning"] }
      },
      "additionalProperties": true
    },
    "faithfulness": {
      "type": "object",
      "properties": {
        "source": { "type": "array", "items": { "type": "string" } },
        "anti_vacuity_checks": { "type": "array", "items": { "type": "string" } },
        "requires_human_confirmation_above_risk": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
