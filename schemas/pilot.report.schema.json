{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openverification.dev/schemas/pilot.report.schema.json",
  "title": "Pilot Report",
  "type": "object",
  "required": ["schema_version", "pilot_dir", "manifests_total", "manifests_passed", "results"],
  "properties": {
    "schema_version": { "const": "ovk.pilot_report.v1" },
    "pilot_dir": { "type": "string", "minLength": 1 },
    "manifests_total": { "type": "integer", "minimum": 1 },
    "manifests_passed": { "type": "integer", "minimum": 0 },
    "results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "manifest",
          "name",
          "lane_count",
          "evidence_count",
          "merge_recommendation",
          "elapsed_ms",
          "passed"
        ],
        "properties": {
          "manifest": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "lane_count": { "type": "integer", "minimum": 1 },
          "evidence_count": { "type": "integer", "minimum": 1 },
          "merge_recommendation": {
            "type": "string",
            "enum": ["allow", "block", "require_human_review", "allow_with_warning", "require_stronger_check"]
          },
          "elapsed_ms": { "type": "number", "minimum": 0 },
          "passed": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
