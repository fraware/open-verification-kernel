{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openverification.dev/schemas/ci_secrets.input.schema.json",
  "title": "CI Secrets Input",
  "type": "object",
  "required": ["workflows"],
  "properties": {
    "author_type": { "type": "string" },
    "agent": { "type": "string" },
    "task": { "type": "string" },
    "trust_context": { "type": "string" },
    "workflows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["workflow_id", "triggers"],
        "properties": {
          "workflow_id": { "type": "string" },
          "triggers": { "type": "array", "items": { "type": "string" } },
          "steps": { "type": "array" },
          "pull_request_target_with_pr_head_checkout": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
