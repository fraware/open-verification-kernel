{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openverification.dev/schemas/holdout.aggregate_metrics.schema.json",
  "title": "FormalPR-Holdout Aggregate Metrics",
  "description": "Publishable aggregate metrics only. Must not embed case ids, labels, diffs, or counterexample text.",
  "type": "object",
  "required": [
    "schema_version",
    "benchmark",
    "holdout_release_tag",
    "ovk_commit_sha",
    "generated_at_unix_ms",
    "lanes",
    "disagreement_summary",
    "leakage_guard"
  ],
  "properties": {
    "schema_version": { "const": "formalpr_holdout.aggregate_metrics.v1" },
    "benchmark": { "const": "FormalPR-Holdout" },
    "holdout_release_tag": { "type": "string" },
    "ovk_commit_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{7,40}$"
    },
    "verified_source_sha": {
      "type": ["string", "null"],
      "pattern": "^[0-9a-f]{7,40}$"
    },
    "generated_at_unix_ms": { "type": "integer", "minimum": 0 },
    "cases_scored": { "type": "integer", "minimum": 0 },
    "lanes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/lane_metrics"
      }
    },
    "disagreement_summary": {
      "type": "object",
      "required": ["open", "resolved", "deferred", "total"],
      "properties": {
        "open": { "type": "integer", "minimum": 0 },
        "resolved": { "type": "integer", "minimum": 0 },
        "deferred": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "reviewer_time": {
      "type": "object",
      "properties": {
        "median_minutes_saved": { "type": ["number", "null"] },
        "median_minutes_added": { "type": ["number", "null"] },
        "notes": {
          "type": "string",
          "description": "Aggregate-only note; no case identifiers."
        }
      },
      "additionalProperties": false
    },
    "leakage_guard": {
      "type": "object",
      "required": ["labels_emitted", "case_ids_emitted", "fail_closed"],
      "properties": {
        "labels_emitted": { "const": false },
        "case_ids_emitted": { "const": false },
        "fail_closed": { "type": "boolean" },
        "sanitizer_version": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "$defs": {
    "lane_metrics": {
      "type": "object",
      "required": [
        "precision",
        "recall",
        "false_positive_rate",
        "missed_detection_rate",
        "unknown_rate",
        "invalid_input_rate",
        "abstention_appropriateness",
        "coverage_completeness",
        "counterexample_correctness",
        "selected_backend_execution_correctness",
        "runtime_ms"
      ],
      "properties": {
        "cases": { "type": "integer", "minimum": 0 },
        "precision": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "recall": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "false_positive_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "missed_detection_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "unknown_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "invalid_input_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "abstention_appropriateness": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "coverage_completeness": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "counterexample_correctness": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "selected_backend_execution_correctness": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        },
        "runtime_ms": {
          "type": "object",
          "required": ["median", "p95", "max"],
          "properties": {
            "median": { "type": "number", "minimum": 0 },
            "p95": { "type": "number", "minimum": 0 },
            "max": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
