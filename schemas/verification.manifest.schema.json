{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openverification.dev/schemas/verification.manifest.schema.json",
  "title": "Verification Manifest",
  "type": "object",
  "required": ["lanes"],
  "properties": {
    "schema_version": { "type": "string", "const": "ovk.verification_manifest.v1" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "repo": { "type": "string", "minLength": 1 },
    "head_sha": { "type": "string", "minLength": 1 },
    "base_sha": { "type": "string", "minLength": 1 },
    "lanes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["lane", "input"],
        "properties": {
          "lane": {
            "type": "string",
            "enum": [
              "self_protection",
              "authorization",
              "infrastructure",
              "ci_secrets",
              "deployment",
              "backend"
            ]
          },
          "input": { "type": "string", "minLength": 1 },
          "input_format": {
            "type": "string",
            "enum": ["infra", "terraform", "kubernetes", "graph", "backend"]
          },
          "policy": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
