{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openverification.dev/schemas/release.layout.schema.json",
  "title": "Release Layout",
  "type": "object",
  "required": ["schema_version", "artifacts"],
  "properties": {
    "schema_version": { "type": "string", "const": "ovk.release_layout.v1" },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "kind"],
        "properties": {
          "path": { "type": "string" },
          "kind": { "type": "string" },
          "required": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
